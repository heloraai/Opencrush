{
  "name": "@openlove/openclaw-plugin",
  "version": "0.1.0",
  "description": "OpenClaw plugin bridge for Openlove — lets OpenClaw manage your companion",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "dependencies": {
    "@openlove/core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
